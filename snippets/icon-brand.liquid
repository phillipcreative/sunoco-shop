{%- doc -%}
  Renders social media brand icons as inline SVGs with consistent styling.

  @param {string} icon - Icon name to render (e.g., 'facebook', 'twitter', 'instagram')
  @param {string} [size] - Icon size: 'sm', 'md', 'lg'
  @param {string} [width] - Custom width in pixels
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'icon-brand',
    icon: 'instagram',
    size: 'lg'
  %}
{%- enddoc -%}

{%- capture class -%}icon icon-{{ icon | handle }} icon-{{ size | default: 'md' }}{% if class != blank %} {{ class }}{% endif %}{%- endcapture -%}
{%- case icon -%}
